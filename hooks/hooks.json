{
  "description": "claude-vault: auto-inject vault notes into session context",
  "hooks": {
    "SessionStart": [
      { "matcher": "startup|clear|compact", "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" skills/vault-loader/scripts/session_start_load.py" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" skills/vault-loader/scripts/prompt_submit_load.py" }] }
    ]
  }
}
